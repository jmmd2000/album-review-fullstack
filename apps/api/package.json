{
  "name": "@album-reviews/api",
  "version": "1.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --legacy-watch --exec tsx src/index.ts",
    "build": "tsc --noEmit && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:push:test": "NODE_ENV=test drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio --verbose",
    "db:seed": "tsx ./src/db/seed.ts",
    "db:wipe": "tsx ./src/db/wipe.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@album-reviews/shared": "workspace:*",
    "@hono/node-server": "^2.0.11",
    "@hono/zod-validator": "^0.9.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express-rate-limit": "8.6.0",
    "extract-colors": "^4.1.1",
    "get-pixels": "^3.3.3",
    "hono": "^4.12.31",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "puppeteer-core": "^24.6.1",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/get-pixels": "^3.3.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
